{
  "manifest_version": 3,
  "name": "Random Wiki in Category",
  "version": "1.0",
  "description": "Open a random Wikipedia article from a chosen category",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Random Wikipedia Article"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://en.wikipedia.org/*"
  ],
  "commands": {
    "button1-action": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "mac": "Command+Shift+1"
      },
      "description": "Trigger Button 1"
    },
    "random-article": {
      "suggested_key": { "default": "Ctrl+Shift+2" },
      "description": "Random article"
    }
  }
}
